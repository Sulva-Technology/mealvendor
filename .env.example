# --- App identity ---
NEXT_PUBLIC_APP_NAME="Meal Direct Vendor"
NEXT_PUBLIC_APP_URL="https://vendor.mealdirectly.com"

# --- Backend API (NestJS) ---
NEXT_PUBLIC_API_BASE_URL="https://mealdirectbackend.onrender.com/v1"

# --- Sibling app URLs (cross-links) ---
NEXT_PUBLIC_USER_APP_URL="https://user.mealdirectly.com"
NEXT_PUBLIC_VENDOR_APP_URL="https://vendor.mealdirectly.com"
NEXT_PUBLIC_RIDER_APP_URL="https://rider.mealdirectly.com"
NEXT_PUBLIC_ADMIN_APP_URL="https://admin.mealdirectly.com"
NEXT_PUBLIC_MARKETING_URL="https://mealdirect.com"
NEXT_PUBLIC_SUPPORT_URL="https://mealdirect.com/support"
NEXT_PUBLIC_PRIVACY_URL="https://mealdirect.com/privacy"
NEXT_PUBLIC_TERMS_URL="https://mealdirectly.com/terms"

# --- Environment / feature flags ---
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_ENABLE_PWA="true"
# Push notifications use Firebase Cloud Messaging. The value below is the FCM
# Web Push certificate ("Voluntary Application Server Identification") public
# key from the Firebase console (Project settings → Cloud Messaging → Web Push
# certificates). Firebase client config lives in src/config/firebase.ts.
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS="false"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Optional integrations ---
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_ASSET_BASE_URL=""

# Where Supabase sends vendors after clicking an auth email link. Forwarded to
# the backend as `redirectTo`; leave unset to use the backend's per-role default.
NEXT_PUBLIC_AUTH_REDIRECT_URL=""
